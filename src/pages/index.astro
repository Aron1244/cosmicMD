---

import '../styles/global.css';
import MarkdownWorkbench from '../components/MarkdownWorkbench';

const fontCards = [
	{
		name: 'Sora',
		stack: '"Sora", "Inter", system-ui, sans-serif',
		sample: 'Editorial clarity with a sharp, modern edge.',
		size: 'text-3xl',
	},
	{
		name: 'Fraunces',
		stack: '"Fraunces", Georgia, serif',
		sample: 'High-contrast serif for refined headings and quotes.',
		size: 'text-3xl',
	},
	{
		name: 'IBM Plex Mono',
		stack: '"IBM Plex Mono", "SFMono-Regular", Consolas, monospace',
		sample: 'Code, labels, tokens, and technical metadata.',
		size: 'text-2xl',
	},
	{
		name: 'Inter Tight',
		stack: '"Inter Tight", "Inter", system-ui, sans-serif',
		sample: 'Compact UI rhythm for dashboards and surfaces.',
		size: 'text-3xl',
	},
];

const palettes = [
	{ name: 'Aurora', value: '#7c3aed', accent: '#22d3ee', surface: '#0f172a' },
	{ name: 'Solar', value: '#f97316', accent: '#fde68a', surface: '#1e293b' },
	{ name: 'Mint', value: '#10b981', accent: '#a7f3d0', surface: '#0f172a' },
	{ name: 'Rose', value: '#fb7185', accent: '#fecdd3', surface: '#1f2937' },
	{ name: 'Cobalt', value: '#2563eb', accent: '#93c5fd', surface: '#111827' },
	{ name: 'Graphite', value: '#111827', accent: '#f3f4f6', surface: '#030712' },
];
---

<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Cosmic MD | Design system preview</title>
		<meta
			name="description"
			content="Una landing moderna para previsualizar tipografías, colores, componentes y estilos de markdown."
		/>
	</head>
	<body class="min-h-screen bg-[#050816] font-sans text-slate-100 antialiased">
		<main class="relative overflow-hidden">
			<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.16),transparent_30%),radial-gradient(circle_at_85%_20%,rgba(124,58,237,0.2),transparent_25%),linear-gradient(180deg,#050816_0%,#0b1120_45%,#050816_100%)]"></div>
			<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(148,163,184,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(148,163,184,0.08)_1px,transparent_1px)] bg-size-[72px_72px] opacity-50"></div>

			<div class="relative mx-auto flex min-h-screen w-full max-w-none flex-col gap-6 px-4 py-5 sm:px-6 lg:px-8">
				<MarkdownWorkbench client:load />

				<footer class="flex flex-col gap-3 border-t border-white/10 pb-6 pt-1 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-between">
					<p>Cosmic MD listo para expandirse a MD, MDX o componentes React si quieres convertirlo en sistema de documentación.</p>
					<p class="text-slate-500">Astro + Tailwind + React</p>
				</footer>
			</div>
		</main>
	</body>
</html>
